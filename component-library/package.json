{
  "name": "frojd-jewl",
  "version": "0.1.4",
  "type": "module",
  "description": "Storybook dev server for Jewl Component Library",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://frojd.github.io/Frojd-Jewl",
  "scripts": {
    "jewl": "node ../cli/bin/run",
    "setup:jewl": "bash scripts/setup-jewl-local.sh",
    "lint": "eslint app",
    "lint:fix": "eslint app --fix",
    "lint:style": "stylelint **/*.scss",
    "lint:style:fix": "stylelint **/*.scss --fix",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "NODE_ENV=production storybook build",
    "deploy-storybook": "gh-pages -d storybook-static",
    "deploy": "rm -rf storybook-static && npm run storybook:build -- --quiet && npm run deploy-storybook",
    "new": "node cli/component/cli.js new",
    "new:container": "node cli/component/cli.js new --container",
    "delete": "node cli/component/cli.js delete",
    "delete:container": "node cli/component/cli.js delete --container",
    "eslint": "eslint app",
    "eslint:fix": "eslint app --fix",
    "fixcode": "npx prettier \"**/*(*.css|*.js|*.json|*.md|*.scss)\" --write",
    "fixcode:test": "prettier \"app/**/*(*.css|*.js|*.json|*.md|*.scss)\" --check",
    "start": "node ./bin/dev-server",
    "svg": "svgo -f app/components/Icon/inline-svg -q --config=app/components/Icon/inline-svg/svgo.config.cjs",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "jest:ci": "npx jest --ci --runInBand --reporters=default --reporters=jest-junit",
    "test": "concurrently \"npm run jest -- --silent --noStackTrace\" \"npm run lint\" \"npm run lint:style\""
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:frojd/frojd-jewl.git"
  },
  "keywords": [
    "react",
    "scss",
    "frontend",
    "boilerplate",
    "storybook"
  ],
  "author": "Fröjd Interactive AB",
  "license": "MIT",
  "browserslist": [
    "last 1 version",
    "> 1%",
    "not dead",
    "ie>=11"
  ],
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-links": "^10.2.15",
    "@storybook/nextjs": "^10.2.15",
    "@storybook/react": "^10.2.15",
    "@swc/core": "^1.4.2",
    "@swc/jest": "^0.2.36",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@whitespace/storybook-addon-html": "^9.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^10.2.15",
    "gh-pages": "^6.1.1",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-test-renderer": "^19.2.4",
    "storybook": "^10.2.15",
    "style-loader": "^4.0.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svgo": "^4.0.1"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@svgr/webpack": "^8.1.0",
    "@types/react": "^19.2.14",
    "classnames": "^2.5.1",
    "framer-motion": "^12.35.0",
    "i18next": "^25.8.14",
    "local-storage": "^2.0.0",
    "next": "^16.1.6",
    "next-i18next": "^15.4.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "sass": "^1.97.3",
    "sharp": "^0.34.5"
  }
}
